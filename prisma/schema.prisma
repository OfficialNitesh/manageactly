// prisma/schema.prisma
// Manage Actly – Multi-tenant SaaS Schema
// PostgreSQL + Prisma ORM
//
// Architectural decisions:
// - Workspace is the tenancy unit (one user can own/join multiple workspaces)
// - WorkspaceMember is the RBAC bridge table (never query User directly for permissions)
// - SocialConnection is per-workspace (team shares a LinkedIn page, not personal accounts)
// - Post soft-deleted via deletedAt (never hard-delete published content)
// - Subscription tied to Workspace, not User (billing is org-level)
// - AuditLog is append-only — no updates, no deletes

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
}

enum PostStatus {
  DRAFT
  SCHEDULED
  PUBLISHING // transient — in-flight to API
  PUBLISHED
  FAILED
}

enum PostPlatform {
  LINKEDIN
  // TWITTER   // future
  // INSTAGRAM // future
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  TRIALING
  INCOMPLETE
}

enum SubscriptionPlan {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

// ─────────────────────────────────────────────────────────────
// USER
// Core identity. Auth is via NextAuth (Google OAuth).
// Users can belong to multiple workspaces.
// ─────────────────────────────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  emailVerified DateTime?

  // NextAuth adapter fields
  accounts Account[]
  sessions Session[]

  // Workspace relationships (via bridge table)
  workspaceMembers WorkspaceMember[]

  // Owned workspaces (convenience — also in WorkspaceMember)
  ownedWorkspaces Workspace[] @relation("WorkspaceOwner")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

// ─────────────────────────────────────────────────────────────
// NEXTAUTH ADAPTER TABLES
// Required by @auth/prisma-adapter
// ─────────────────────────────────────────────────────────────
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────────────────────
// WORKSPACE
// Tenancy unit. One workspace = one team/brand.
// Billing, social connections, and posts are all workspace-scoped.
// ─────────────────────────────────────────────────────────────
model Workspace {
  id   String @id @default(cuid())
  name String
  slug String @unique // URL-safe identifier, e.g. "acme-corp"

  // Owner is denormalized here for fast queries.
  // Source of truth is WorkspaceMember with role=OWNER.
  ownerId String
  owner   User   @relation("WorkspaceOwner", fields: [ownerId], references: [id])

  members           WorkspaceMember[]
  socialConnections SocialConnection[]
  posts             Post[]
  subscription      Subscription?
  auditLogs         AuditLog[]

  // Soft delete
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@index([slug])
  @@index([deletedAt])
}

// ─────────────────────────────────────────────────────────────
// WORKSPACE MEMBER (RBAC)
// Bridge table between User and Workspace.
// Always check permissions via this table, never User directly.
// ─────────────────────────────────────────────────────────────
model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(MEMBER)

  // Invitation tracking
  invitedByUserId String?
  acceptedAt      DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, userId]) // one role per user per workspace
  @@index([workspaceId])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────
// SOCIAL CONNECTION
// Stores OAuth tokens for connected social accounts.
// Encrypted at rest (see lib/crypto.ts).
// One workspace can have one connection per platform.
// ─────────────────────────────────────────────────────────────
model SocialConnection {
  id          String       @id @default(cuid())
  workspaceId String
  platform    PostPlatform

  // LinkedIn-specific fields
  platformUserId   String // LinkedIn member URN
  platformUserName String? // Display name

  // Tokens — stored encrypted in DB
  // Use AES-256-GCM via lib/crypto.ts
  accessToken           String    @db.Text // encrypted
  refreshToken          String?   @db.Text // encrypted (LinkedIn has long-lived tokens)
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?

  // Scopes granted by user
  scopes String[] @default([])

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // Soft delete (revoking connection)
  revokedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, platform]) // one connection per platform per workspace
  @@index([workspaceId])
  @@index([platform])
}

// ─────────────────────────────────────────────────────────────
// POST
// Core content entity. Platform-specific content stored as JSON
// to allow platform-specific fields without schema migrations.
// ─────────────────────────────────────────────────────────────
model Post {
  id          String       @id @default(cuid())
  workspaceId String
  platform    PostPlatform @default(LINKEDIN)
  status      PostStatus   @default(DRAFT)

  // Content
  content   String   @db.Text // raw text content
  mediaUrls String[] @default([]) // attached media
  hashtags  String[] @default([])

  // AI metadata
  aiGenerated Boolean @default(false)
  aiPrompt    String? @db.Text // original user prompt
  aiModel     String? // e.g. "gpt-4o-mini"

  // Scheduling
  scheduledAt DateTime? // null = unscheduled
  publishedAt DateTime? // set on successful publish

  // Publishing result
  platformPostId String? // LinkedIn post URN on success
  failureReason  String?   @db.Text
  retryCount     Int       @default(0)
  lastRetriedAt  DateTime?

  // Idempotency — prevents double-publish in cron
  publishingLockAt DateTime? // set when cron picks up this post

  // Creator
  createdByUserId String

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // Soft delete
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Indexes for scheduler query: WHERE status=SCHEDULED AND scheduledAt <= now()
  @@index([workspaceId])
  @@index([status])
  @@index([scheduledAt])
  @@index([status, scheduledAt]) // compound — used by cron job
  @@index([deletedAt])
  @@index([createdByUserId])
}

// ─────────────────────────────────────────────────────────────
// SUBSCRIPTION
// One subscription per workspace (org-level billing).
// Payment collected via direct UPI transfers (no gateway).
// ─────────────────────────────────────────────────────────────
model Subscription {
  id          String @id @default(cuid())
  workspaceId String @unique // one subscription per workspace

  // Payment provider (upi | future: stripe, etc)
  provider String @default("upi")

  // Payment tracking (UTR-based for UPI)
  upiPaymentId  String?   // UTR or transaction reference
  upiTimestamp  DateTime? // When payment was verified

  // Plan & Status
  plan   SubscriptionPlan   @default(FREE)
  status SubscriptionStatus @default(TRIALING)

  // Billing dates
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  trialEndsAt        DateTime?
  cancelledAt        DateTime?

  // Limits (denormalized for fast gating — avoid join on every API call)
  postsPerMonth     Int @default(10) // FREE tier
  aiCreditsPerMonth Int @default(20) // FREE tier

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────
// AUDIT LOG
// Append-only activity log. Never update, never delete.
// Used for debugging, compliance, and support.
// ─────────────────────────────────────────────────────────────
model AuditLog {
  id          String @id @default(cuid())
  workspaceId String

  // Who did it (null = system/cron)
  actorId    String?
  actorEmail String?

  // What happened
  action   String // e.g. "post.published", "subscription.activated"
  entity   String // e.g. "Post", "Subscription"
  entityId String? // ID of affected entity

  // Payload — store diffs or relevant context
  metadata Json? @default("{}")

  // IP for security audit
  ipAddress String?

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  createdAt DateTime @default(now())

  @@index([workspaceId])
  @@index([actorId])
  @@index([action])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────
// LEAD
// Stores leads from the "Book a Pilot" form on landing pages.
// ─────────────────────────────────────────────────────────────
model Lead {
  id          String   @id @default(cuid())
  name        String
  email       String   @db.VarChar(255)
  companyName String?
  message     String?  @db.Text
  createdAt   DateTime @default(now())

  @@index([email])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────
// APPLICANT
// Stores career applications from the "Apply Now" and
// "Send Your Portfolio" buttons on the careers page.
// ─────────────────────────────────────────────────────────────
model Applicant {
  id             String   @id @default(cuid())
  name           String
  email          String   @db.VarChar(255)
  phone          String?  @db.VarChar(20)
  roleAppliedFor String // e.g., "Content Writer", "Graphic Designer"
  portfolioLink  String?  @db.Text
  appliedAt      DateTime @default(now())

  @@index([email])
  @@index([roleAppliedFor])
  @@index([appliedAt])
}

// ─────────────────────────────────────────────────────────────
// PORTFOLIO SUBMISSION
// Stores submissions from the "Send Your Portfolio" form.
// ─────────────────────────────────────────────────────────────
model PortfolioSubmission {
  id            String   @id @default(cuid())
  name          String
  email         String   @db.VarChar(255)
  portfolioLink String   @db.Text
  message       String?  @db.Text
  createdAt     DateTime @default(now())

  @@index([email])
  @@index([createdAt])
  @@map("portfolio_submissions")
}
